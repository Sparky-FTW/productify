{
  "compilerOptions": {
    "rootDir": "./src", 
    "outDir": "./dist", 
    "module": "NodeNext", 
    "moduleResolution": "NodeNext",
    "target": "es2022", 
    "esModuleInterop": true, 
    "strict": true, 
    "skipLibCheck": true, 
    "resolveJsonModule": true, 
    "forceConsistentCasingInFileNames": true,
  },
  "include": ["src/**/*.ts"], 
  "exclude": ["node_modules"] 
}